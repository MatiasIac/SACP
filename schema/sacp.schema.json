{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sacp.dev/schema/sacp-v1.0.0.schema.json",
  "title": "SACP Message v1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["proto_ver", "msg_id", "ts", "sender", "g", "plan", "state"],
  "properties": {
    "proto_ver": {
      "type": "string",
      "const": "1.0.0"
    },
    "msg_id": {
      "$ref": "#/$defs/identifier"
    },
    "reply_to": {
      "$ref": "#/$defs/identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "sender": {
      "$ref": "#/$defs/identifier"
    },
    "recipient": {
      "$ref": "#/$defs/identifier"
    },
    "g": {
      "$ref": "#/$defs/goal"
    },
    "ctx": {
      "type": "object"
    },
    "plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/plan_step"
      }
    },
    "out_fmt": {
      "$ref": "#/$defs/out_fmt"
    },
    "state": {
      "$ref": "#/$defs/state"
    },
    "result": {
      "$ref": "#/$defs/result"
    },
    "error": {
      "$ref": "#/$defs/error"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "test_mode": {
      "type": "boolean"
    },
    "ext": {
      "$ref": "#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "const": "DONE"
          }
        },
        "required": ["state"]
      },
      "then": {
        "required": ["result"]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "FAILED"
          }
        },
        "required": ["state"]
      },
      "then": {
        "required": ["error"]
      }
    },
    {
      "if": {
        "required": ["result"]
      },
      "then": {
        "not": {
          "required": ["error"]
        }
      }
    },
    {
      "if": {
        "required": ["error"]
      },
      "then": {
        "not": {
          "required": ["result"]
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "step_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "goal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "out_fmt": {
      "type": "string",
      "enum": ["raw", "summary", "human"]
    },
    "state": {
      "type": "string",
      "enum": ["PENDING", "ACCEPTED", "IN_PROGRESS", "WAITING", "DONE", "FAILED", "CANCELLED"]
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_attempts"],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "backoff_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 600000
        },
        "strategy": {
          "type": "string",
          "enum": ["fixed", "exponential"]
        }
      }
    },
    "plan_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "verb", "tool", "params"],
      "properties": {
        "id": {
          "$ref": "#/$defs/step_id"
        },
        "verb": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "tool": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "params": {
          "type": "object"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step_id"
          },
          "uniqueItems": true
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600000
        },
        "retry": {
          "$ref": "#/$defs/retry"
        },
        "on_error": {
          "type": "string",
          "enum": ["fail_fast", "continue", "fallback"]
        },
        "fallback_step": {
          "$ref": "#/$defs/step_id"
        },
        "output_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "on_error": {
                "const": "fallback"
              }
            },
            "required": ["on_error"]
          },
          "then": {
            "required": ["fallback_step"]
          }
        }
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outputs"],
      "properties": {
        "outputs": {
          "type": "object"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "step_results": {
          "type": "object"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z0-9_]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "step_id": {
          "$ref": "#/$defs/step_id"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object"
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "$ref": "#/$defs/identifier"
        },
        "span_id": {
          "$ref": "#/$defs/identifier"
        },
        "parent_span_id": {
          "$ref": "#/$defs/identifier"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "latency_ms": {
              "type": "integer",
              "minimum": 0
            },
            "queue_ms": {
              "type": "integer",
              "minimum": 0
            },
            "tool_calls": {
              "type": "integer",
              "minimum": 0
            },
            "tokens_in": {
              "type": "integer",
              "minimum": 0
            },
            "tokens_out": {
              "type": "integer",
              "minimum": 0
            },
            "cost_usd": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9]+\\.[A-Za-z0-9_.-]+$": true
      },
      "additionalProperties": false
    }
  }
}
